# Lharmonie Dashboard — env vars de ejemplo.
# Copialo a .env.local para dev y configurá los valores reales en Vercel para prod.

# ─── Google OAuth (login) ────────────────────────────────────────────
# Mismo Client ID que el staff app (cronklam GCP project).
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# String random largo para firmar cookies HMAC. Min 16 chars en prod.
# IMPORTANTE: NO usar el mismo valor que el staff. Generar con:
#   openssl rand -base64 32
AUTH_SECRET=

# ─── Google Sheets (lectura del Sheet de Facturas) ──────────────────
# API Key de la consola de Google con acceso a Sheets API.
GOOGLE_API_KEY=

# Sheet ID de "Facturas Lharmonie".
FACTURAS_SHEET_ID=

# ─── Google Sheets (escritura — service account) ────────────────────
# JSON entero del service account, en una sola línea (sin saltos).
# Mismo service account del staff sirve, siempre que esté
# compartido como Editor en cada Sheet listado abajo.
GOOGLE_CREDENTIALS=

# Sheet ID de Servicios (catálogo + pagos + Baigun ctacte).
# El service account tiene que tener acceso de Editor.
SERVICIOS_SHEET_ID=

# Sheet ID de Caja (chica + grande + sesiones).
CAJA_SHEET_ID=

# Tab names. Defaults heredados del staff. Si tus tabs tienen otros
# nombres, sobreescribilos acá. NO se autocrean — el tab tiene que
# existir o el endpoint devuelve error.
SERVICIOS_CATALOGO_TAB=Servicios Catalogo
SERVICIOS_PAGOS_TAB=Servicios Pagos
BAIGUN_CTA_CTE_TAB=Baigun CtaCte
CAJA_CHICA_MOV_TAB=CajaChica_Movimientos
CAJA_CHICA_SES_TAB=CajaChica_Sesiones
CAJA_GRANDE_TAB=CajaGrande_Movimientos
